#!/bin/sh

dwm_battery () {
    # Change BAT1 to whatever your battery is identified as. Typically BAT0 or BAT1
    	CHARGE=$(cat /sys/class/power_supply/BAT1/capacity)
    	STATUS=$(cat /sys/class/power_supply/BAT1/status)
     if   [ "${CHARGE}" -lt 10 ];  then ICON="َ±ƒچ"
     elif [ "${CHARGE}" -lt 20 ];  then ICON="َ°پ؛"
     elif [ "${CHARGE}" -lt 30 ];  then ICON="َ°پ»"
     elif [ "${CHARGE}" -lt 40 ];  then ICON="َ°پ¼"
     elif [ "${CHARGE}" -lt 50 ];  then ICON="َ°پ½"
     elif [ "${CHARGE}" -lt 60 ];  then ICON="َ°پ¾"
     elif [ "${CHARGE}" -lt 70 ];  then ICON="َ°پ؟"
     elif [ "${CHARGE}" -lt 80 ];  then ICON="َ°‚€"
     elif [ "${CHARGE}" -lt 90 ];  then ICON="َ°‚پ"
     elif [ "${CHARGE}" -lt 99 ];  then ICON="َ°‚‚"
     elif [ "${CHARGE}" -lt 101 ]; then ICON="َ°پ¹"
     fi
    	if [ "$STATUS" = "Charging" ]; then
		printf "%sَ±گ‹" "$ICON"
    		#printf "%sَ±گ‹ %s%%" "$ICON" "$CHARGE"
    	elif [ "$STATUS" = "Not charging" ]; then
		printf "%s!" "$ICON"
    		#printf "%s! %s%%" "$ICON" "$CHARGE"
    	elif [ "$STATUS" = "Unknown" ]; then
		printf "%s?" "$ICON"
    		#printf "%s? %s%%" "$ICON" "$CHARGE"
	else
		printf "%s" "$ICON"
    		#printf "%s %s%%" "$ICON" "$CHARGE"
	fi
}
dwm_battery
